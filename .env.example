# Database connection (local or cloud)
DATABASE_URL=postgresql://user:pass@host:5432/vetcloud

# Server port
PORT=8055

# App API URL (used by the mobile/web app)
EXPO_PUBLIC_API_URL=http://localhost:8055

# JWT secret (REQUIRED - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-random-secret-here

# SMTP for sending prescription emails
SMTP_SERVICE=gmail
SMTP_EMAIL=noreply.vetcloud@gmail.com
SMTP_PASSWORD=your-app-password
