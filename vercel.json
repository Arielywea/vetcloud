{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "memory": 256
    }
  },
  "rewrites": [
    { "source": "/items/(.*)", "destination": "/api" },
    { "source": "/admin", "destination": "/api" },
    { "source": "/admin/(.*)", "destination": "/api" },
    { "source": "/files", "destination": "/api" },
    { "source": "/uploads/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
